# Load fleet defaults, then user overrides.
# .env.example provides defaults; .env (gitignored) overrides them.

ENVRC_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

if [[ -f "${ENVRC_DIR}/.env.example" ]]; then
    set -a
    . "${ENVRC_DIR}/.env.example"
    set +a
fi

if [[ -f "${ENVRC_DIR}/.env" ]]; then
    set -a
    . "${ENVRC_DIR}/.env"
    set +a
fi
