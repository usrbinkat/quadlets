# =============================================================================
# Minecraft Fleet Shared Secrets
# =============================================================================
# Deployed by cloud-init to: ~/.config/containers/systemd/minecraft-secrets.env
# Permissions: 0600 (owner read/write only)
#
# EnvironmentFile= does NOT perform shell variable expansion.
# All derived variables must be written explicitly here.
#
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 32
# Rotate: update this file, restart all services.
# =============================================================================

# HmacSHA256 forwarding secret (shared between proxy and all backends)
MINECRAFT_FORWARDING_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Velocity proxy reads this env var directly (VelocityConfiguration.java line 525)
VELOCITY_FORWARDING_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Paper/NeoForge backends use this via PATCH_DEFINITIONS ${CFG_VELOCITY_SECRET}
CFG_VELOCITY_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# All three values MUST be identical. They exist as separate vars because:
# - VELOCITY_FORWARDING_SECRET: read by Velocity JVM System.getenv()
# - CFG_VELOCITY_SECRET: consumed by PATCH_DEFINITIONS ${} substitution
# - MINECRAFT_FORWARDING_SECRET: canonical name for documentation/rotation
