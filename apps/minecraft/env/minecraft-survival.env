# =============================================================================
# Minecraft Server: survival (Paper, near-vanilla with QoL)
# =============================================================================

EULA=TRUE
TYPE=PAPER
VERSION=LATEST
ONLINE_MODE=false
ENFORCE_SECURE_PROFILE=false

# JVM (Aikar's G1GC flags applied by USE_AIKAR_FLAGS)
# Xms=Xmx prevents heap resizing; AlwaysPreTouch faults pages at startup
# Compact Object Headers (JEP 519, Java 25): 10-20% heap reduction
# HeapDump + ExitOnOOM: graceful crash before cgroup OOM killer fires
# Container Memory=5g; leave 1.5G for metaspace/netty/stacks/plugins
INIT_MEMORY=3500M
MAX_MEMORY=3500M
USE_AIKAR_FLAGS=true
JVM_XX_OPTS=-XX:+UseCompactObjectHeaders -XX:+HeapDumpOnOutOfMemoryError -XX:+ExitOnOutOfMemoryError

# Velocity forwarding via PATCH_DEFINITIONS
PATCH_DEFINITIONS=/config/patches

# --- Plugins (Modrinth slugs, resolved by mc-image-helper) ---
MODRINTH_PROJECTS=essentialsx,coreprotect,griefprevention,libertybans,chunky,gsit,fancyholograms,bluemap,toolstats,worldedit,sleepskipultra

# Game
DIFFICULTY=normal
MODE=survival
MAX_PLAYERS=20
# View/simulation distance tuned for MSPT headroom on 2C/4T
# Simulation cost scales with square of distance; keep sim <= view
VIEW_DISTANCE=8
SIMULATION_DISTANCE=6
PVP=true
SPAWN_PROTECTION=16
OVERRIDE_SERVER_PROPERTIES=true
GENERATE_STRUCTURES=true
ALLOW_NETHER=true
SPAWN_ANIMALS=true
SPAWN_MONSTERS=true
SPAWN_NPCS=true

# Native idle pause (MC 1.21.2+, no CAP_NET_RAW needed)
PAUSE_WHEN_EMPTY_SECONDS=300

# Disable watchdog — pause-when-empty resume looks like one long tick
MAX_TICK_TIME=-1

# Identity
MOTD=BrainCraft - Survival
OPS=usrbinkat
WHITELIST=usrbinkat,gardengnomegal8,Sgt_Ramirez,microbeast,H0WZ0R
ENABLE_WHITELIST=true
EXISTING_WHITELIST_FILE=SYNC_FILE_MERGE_LIST
EXISTING_OPS_FILE=SYNC_FILE_MERGE_LIST

# Graceful shutdown (StopTimeout=130 in .container = STOP_DURATION + ANNOUNCE_DELAY + buffer)
STOP_DURATION=120
STOP_SERVER_ANNOUNCE_DELAY=5

# RCON (required for mc-health and graceful stop)
ENABLE_RCON=true

# Timezone
TZ=America/Los_Angeles

# Logging
ENABLE_ROLLING_LOGS=true
LOG_TIMESTAMP=true

# RCON automation
RCON_CMDS_FIRST_CONNECT=say Welcome to Survival!
RCON_CMDS_LAST_DISCONNECT=save-all
