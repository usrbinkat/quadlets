# =============================================================================
# Minecraft Server: modded (NeoForge, survival with mods)
# =============================================================================

EULA=TRUE
TYPE=NEOFORGE
ONLINE_MODE=false
ENFORCE_SECURE_PROFILE=false

# Version auto-selected from mod compatibility
VERSION_FROM_MODRINTH_PROJECTS=true

# Mods: performance (non-optional) + infrastructure + content
MODRINTH_PROJECTS=neovelocity,lithium,spark,chunky,ferrite-core,modernfix-mvus,c2me-neoforge,alternate-current,terralith,bluemap
MODRINTH_DOWNLOAD_DEPENDENCIES=required

# JVM (must be below container Memory=7g; 1GB overhead for metaspace/netty/stacks)
INIT_MEMORY=6G
MAX_MEMORY=6G
USE_AIKAR_FLAGS=true
JVM_XX_OPTS=-XX:+HeapDumpOnOutOfMemoryError -XX:+ExitOnOutOfMemoryError

# Velocity forwarding via PATCH_DEFINITIONS (NeoVelocity mod)
PATCH_DEFINITIONS=/config/patches

# Game
DIFFICULTY=hard
MODE=survival
MAX_PLAYERS=20
# Tighter than creative — NeoForge mod tick overhead + hard difficulty + Terralith
VIEW_DISTANCE=8
SIMULATION_DISTANCE=6
PVP=true
SPAWN_PROTECTION=16
OVERRIDE_SERVER_PROPERTIES=true
GENERATE_STRUCTURES=true
ALLOW_NETHER=true
SPAWN_ANIMALS=true
SPAWN_MONSTERS=true
SPAWN_NPCS=true
# Disable watchdog — pause-when-empty makes one very long tick on resume
MAX_TICK_TIME=-1

# Native idle pause
PAUSE_WHEN_EMPTY_SECONDS=300

# Identity
MOTD=BrainCraft - Modded (NeoForge)
OPS=usrbinkat
WHITELIST=usrbinkat,gardengnomegal8
ENABLE_WHITELIST=true
EXISTING_WHITELIST_FILE=SYNC_FILE_MERGE_LIST
EXISTING_OPS_FILE=SYNC_FILE_MERGE_LIST

# Graceful shutdown (NeoForge saves slower; StopTimeout=190)
STOP_DURATION=180
STOP_SERVER_ANNOUNCE_DELAY=5

# RCON
ENABLE_RCON=true

# Timezone
TZ=America/Los_Angeles

# Logging
ENABLE_ROLLING_LOGS=true
LOG_TIMESTAMP=true

# RCON automation
RCON_CMDS_FIRST_CONNECT=say Welcome to Modded!
RCON_CMDS_LAST_DISCONNECT=save-all
