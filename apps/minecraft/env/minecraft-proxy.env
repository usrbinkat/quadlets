# =============================================================================
# Minecraft Velocity Proxy Configuration
# =============================================================================

# --- Proxy Type ---
TYPE=VELOCITY
VELOCITY_VERSION=latest

# --- JVM ---
MEMORY=512m

# --- Config Template Processing ---
# REPLACE_ENV_VARIABLES: processes /config/velocity.toml template, writes to /server/velocity.toml
# ENV_VARIABLE_PREFIX: only ${CFG_*} placeholders are expanded
REPLACE_ENV_VARIABLES=TRUE
ENV_VARIABLE_PREFIX=CFG_

# --- DNS Cache ---
# When backends restart and get new bridge IPs, stale DNS must clear quickly.
NETWORKADDRESS_CACHE_TTL=60

# --- Velocity Plugins (Modrinth slugs) ---
MODRINTH_PROJECTS=viaversion,viabackwards,geyser,floodgate,luckperms,maintenance

# --- velocity.toml template variables (CFG_ prefix) ---
CFG_BIND=0.0.0.0:25565
CFG_MOTD=<gradient:#09add3:#4af7c4>BrainCraft Minecraft Network</gradient>
CFG_SHOW_MAX_PLAYERS=100
CFG_ONLINE_MODE=true
CFG_FORCE_KEY_AUTH=true
CFG_PLAYER_INFO_FORWARDING_MODE=modern
CFG_ANNOUNCE_FORGE=true
CFG_KICK_EXISTING=true
CFG_PING_PASSTHROUGH=DISABLED
CFG_ENABLE_PLAYER_ADDRESS_LOGGING=false
CFG_TCP_FAST_OPEN=true
CFG_LOG_COMMAND_EXECUTIONS=true
CFG_LOG_PLAYER_CONNECTIONS=true
CFG_FAILOVER=true

# --- Server addresses (resolved via aardvark-dns on minecraft bridge) ---
CFG_SERVER_SURVIVAL=minecraft-survival:25565
CFG_SERVER_CREATIVE=minecraft-creative:25565
CFG_SERVER_MODDED=minecraft-modded:25565
CFG_SERVER_INSANE=minecraft-insane:25565

# --- Forced hosts (must be lowercase per Velocity source) ---
CFG_HOST_SURVIVAL=survival.play.braincraft.io
CFG_HOST_CREATIVE=creative.play.braincraft.io
CFG_HOST_MODDED=modded.play.braincraft.io
CFG_HOST_INSANE=insane.play.braincraft.io
