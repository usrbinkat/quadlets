# =============================================================================
# Minecraft Server: creative (Paper, sandbox art studio)
# =============================================================================

EULA=TRUE
TYPE=PAPER
VERSION=LATEST
ONLINE_MODE=false
ENFORCE_SECURE_PROFILE=false

# JVM
INIT_MEMORY=2G
MAX_MEMORY=4G
USE_AIKAR_FLAGS=true

# Velocity forwarding via PATCH_DEFINITIONS
PATCH_DEFINITIONS=/config/patches

# --- Plugins (Modrinth slugs, resolved by mc-image-helper) ---
MODRINTH_PROJECTS=essentialsx,coreprotect,libertybans,chunky,gsit,fancyholograms,bluemap,fastasyncworldedit,doubledoors,sleepskipultra,chestsort

# Game
DIFFICULTY=peaceful
MODE=creative
MAX_PLAYERS=20
VIEW_DISTANCE=16
SIMULATION_DISTANCE=10
PVP=false
SPAWN_PROTECTION=0
OVERRIDE_SERVER_PROPERTIES=true
FORCE_GAMEMODE=true
ALLOW_FLIGHT=true
ENABLE_COMMAND_BLOCK=true
MAX_BUILD_HEIGHT=1024
GENERATE_STRUCTURES=true
ALLOW_NETHER=true
SPAWN_ANIMALS=true
SPAWN_MONSTERS=false
SPAWN_NPCS=true

# Native idle pause
PAUSE_WHEN_EMPTY_SECONDS=300

# Identity
MOTD=BrainCraft - Creative
OPS=usrbinkat
WHITELIST=usrbinkat,gardengnomegal8
ENABLE_WHITELIST=true
EXISTING_WHITELIST_FILE=SYNC_FILE_MERGE_LIST
EXISTING_OPS_FILE=SYNC_FILE_MERGE_LIST

# Graceful shutdown
STOP_DURATION=120
STOP_SERVER_ANNOUNCE_DELAY=5

# RCON
ENABLE_RCON=true

# Timezone
TZ=America/Los_Angeles

# Logging
ENABLE_ROLLING_LOGS=true
LOG_TIMESTAMP=true

# RCON automation
RCON_CMDS_FIRST_CONNECT=say Welcome to Creative!
RCON_CMDS_LAST_DISCONNECT=save-all
