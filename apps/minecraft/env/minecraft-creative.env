# =============================================================================
# Minecraft Server: creative (Paper, sandbox art studio)
# =============================================================================

EULA=TRUE
TYPE=PAPER
VERSION=LATEST
ONLINE_MODE=false
ENFORCE_SECURE_PROFILE=false

# JVM
# Container Memory=12g; leave 2g for metaspace/netty/plugins
INIT_MEMORY=10G
MAX_MEMORY=10G
USE_AIKAR_FLAGS=true
JVM_XX_OPTS=-XX:+UseCompactObjectHeaders -XX:+HeapDumpOnOutOfMemoryError -XX:+ExitOnOutOfMemoryError

# Patches
PATCH_DEFINITIONS=/config/creative/patches

# Plugins
MODRINTH_PROJECTS=essentialsx,coreprotect,libertybans,chunky,gsit,fancyholograms,bluemap,fastasyncworldedit,sleepskipultra

# Game
DIFFICULTY=peaceful
MODE=creative
MAX_PLAYERS=20
VIEW_DISTANCE=16
SIMULATION_DISTANCE=8
PVP=false
SPAWN_PROTECTION=0
OVERRIDE_SERVER_PROPERTIES=true
FORCE_GAMEMODE=true
ALLOW_FLIGHT=true
ENABLE_COMMAND_BLOCK=true
MAX_BUILD_HEIGHT=1024
GENERATE_STRUCTURES=true
ALLOW_NETHER=true
SPAWN_ANIMALS=true
SPAWN_MONSTERS=false
SPAWN_NPCS=true
PAUSE_WHEN_EMPTY_SECONDS=300
MAX_TICK_TIME=-1

# Identity
MOTD=BrainCraft - Creative
OPS=usrbinkat
WHITELIST=usrbinkat,gardengnomegal8,Sgt_Ramirez,microbeast,H0WZ0R
ENABLE_WHITELIST=true
EXISTING_WHITELIST_FILE=SYNC_FILE_MERGE_LIST
EXISTING_OPS_FILE=SYNC_FILE_MERGE_LIST

# Lifecycle
STOP_DURATION=120
STOP_SERVER_ANNOUNCE_DELAY=5
ENABLE_RCON=true
TZ=America/Los_Angeles
ENABLE_ROLLING_LOGS=true
LOG_TIMESTAMP=true
RCON_CMDS_FIRST_CONNECT=say Welcome to Creative!
RCON_CMDS_LAST_DISCONNECT=save-all
