# =============================================================================
# Minecraft Server: insane (NeoForge, creative with mods)
# =============================================================================

EULA=TRUE
TYPE=NEOFORGE
VERSION=1.21.11
ONLINE_MODE=false
ENFORCE_SECURE_PROFILE=false

# Mods
MODRINTH_PROJECTS=neovelocity,lithium,spark,chunky,ferrite-core,modernfix-mvus,c2me-neoforge,alternate-current,bluemap
MODRINTH_DOWNLOAD_DEPENDENCIES=required
MODRINTH_PROJECTS_DEFAULT_VERSION_TYPE=alpha

# JVM
# Container Memory=12g; leave 5g for metaspace/netty/NeoForge mixin/class loading
# AlwaysPreTouch (Aikar flags) touches all heap pages at JVM start; combined
# with NeoForge mixin bootstrap, peak RSS briefly exceeds heap+2g.
INIT_MEMORY=7G
MAX_MEMORY=7G
USE_AIKAR_FLAGS=true
JVM_XX_OPTS=-XX:+HeapDumpOnOutOfMemoryError -XX:+ExitOnOutOfMemoryError

# Patches
PATCH_DEFINITIONS=/config/insane/patches

# Game
DIFFICULTY=peaceful
MODE=creative
MAX_PLAYERS=20
VIEW_DISTANCE=12
SIMULATION_DISTANCE=8
PVP=false
SPAWN_PROTECTION=0
OVERRIDE_SERVER_PROPERTIES=true
FORCE_GAMEMODE=true
ALLOW_FLIGHT=true
ENABLE_COMMAND_BLOCK=true
MAX_BUILD_HEIGHT=1024
GENERATE_STRUCTURES=true
ALLOW_NETHER=true
SPAWN_ANIMALS=true
SPAWN_MONSTERS=false
SPAWN_NPCS=true
PAUSE_WHEN_EMPTY_SECONDS=300
MAX_TICK_TIME=-1

# Identity
MOTD=BrainCraft - Insane (NeoForge)
OPS=usrbinkat
WHITELIST=usrbinkat,gardengnomegal8,Sgt_Ramirez,SgtRemeriz,Sgt_Remeriz,microbeast,H0WZ0R,Microbeaster485
ENABLE_WHITELIST=true
EXISTING_WHITELIST_FILE=SYNC_FILE_MERGE_LIST
EXISTING_OPS_FILE=SYNC_FILE_MERGE_LIST

# Lifecycle
STOP_DURATION=180
STOP_SERVER_ANNOUNCE_DELAY=5
ENABLE_RCON=true
TZ=America/Los_Angeles
ENABLE_ROLLING_LOGS=true
LOG_TIMESTAMP=true
RCON_CMDS_FIRST_CONNECT=say Welcome to Insane!
RCON_CMDS_LAST_DISCONNECT=save-all
