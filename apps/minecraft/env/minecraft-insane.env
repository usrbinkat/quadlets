# =============================================================================
# Minecraft Server: insane (NeoForge, creative with mods)
# =============================================================================

EULA=TRUE
TYPE=NEOFORGE
ONLINE_MODE=false
ENFORCE_SECURE_PROFILE=false

# Pin to 1.21.11 — the only NeoForge MC version where all mods have builds.
VERSION=1.21.11

# Mods: performance (non-optional) + infrastructure
MODRINTH_PROJECTS=neovelocity,lithium,spark,chunky,ferrite-core,modernfix-mvus,c2me-neoforge,alternate-current,bluemap
MODRINTH_DOWNLOAD_DEPENDENCIES=required

# JVM (must be below container Memory=7g; 1GB overhead for metaspace/netty/stacks)
INIT_MEMORY=6G
MAX_MEMORY=6G
USE_AIKAR_FLAGS=true
JVM_XX_OPTS=-XX:+HeapDumpOnOutOfMemoryError -XX:+ExitOnOutOfMemoryError

# Velocity forwarding via PATCH_DEFINITIONS (NeoVelocity mod)
PATCH_DEFINITIONS=/config/patches

# Game
DIFFICULTY=peaceful
MODE=creative
MAX_PLAYERS=20
VIEW_DISTANCE=12
SIMULATION_DISTANCE=8
PVP=false
SPAWN_PROTECTION=0
OVERRIDE_SERVER_PROPERTIES=true
FORCE_GAMEMODE=true
ALLOW_FLIGHT=true
ENABLE_COMMAND_BLOCK=true
MAX_BUILD_HEIGHT=1024
GENERATE_STRUCTURES=true
ALLOW_NETHER=true
SPAWN_ANIMALS=true
SPAWN_MONSTERS=false
SPAWN_NPCS=true
# Disable watchdog — pause-when-empty makes one very long tick on resume
MAX_TICK_TIME=-1

# Native idle pause
PAUSE_WHEN_EMPTY_SECONDS=300

# Identity
MOTD=BrainCraft - Insane (NeoForge)
OPS=usrbinkat
WHITELIST=usrbinkat,gardengnomegal8
ENABLE_WHITELIST=true
EXISTING_WHITELIST_FILE=SYNC_FILE_MERGE_LIST
EXISTING_OPS_FILE=SYNC_FILE_MERGE_LIST

# Graceful shutdown
STOP_DURATION=180
STOP_SERVER_ANNOUNCE_DELAY=5

# RCON
ENABLE_RCON=true

# Timezone
TZ=America/Los_Angeles

# Logging
ENABLE_ROLLING_LOGS=true
LOG_TIMESTAMP=true

# RCON automation
RCON_CMDS_FIRST_CONNECT=say Welcome to Insane!
RCON_CMDS_LAST_DISCONNECT=save-all
