# =============================================================================
# Minecraft Fleet Configuration
# =============================================================================
# Default fleet tunables. Sourced by .envrc, then overridden by .env if present.
#
# To customize: cp .env.example .env && edit .env
# Only values that differ from defaults need to appear in .env.
# =============================================================================

# --- World enablement ---
# Controls which backend worlds deploy.sh installs and enable.sh starts.
# The proxy always starts. Set to "true" or "false".
FLEET_SURVIVAL=true
FLEET_CREATIVE=true
FLEET_MODDED=false
FLEET_INSANE=false

# --- Container memory ---
# deploy.sh generates Quadlet drop-in files from these values, overriding
# Memory=, memory.high, and MemoryHigh= per container. The base quadlet
# files define defaults; drop-ins provide the override vector.
# Must fit within VM RAM minus ~2Gi OS overhead.
# 28Gi VM: proxy(2g) + survival(12g) + creative(12g) = 26g
# 52Gi VM: proxy(2g) + 4 worlds(12g each) = 50g
FLEET_PROXY_MEMORY=2g
FLEET_SURVIVAL_MEMORY=12g
FLEET_CREATIVE_MEMORY=12g
FLEET_MODDED_MEMORY=12g
FLEET_INSANE_MEMORY=12g

# --- BlueMap web server ---
# Each backend publishes BlueMap's web UI on a unique host port.
# Base port + world index: survival=8100, creative=8101, modded=8102, insane=8103.
# BlueMap inside each container always listens on 8100; the host port differentiates.
# deploy.sh generates a 40-bluemap.conf drop-in with PublishPort=<host>:8100.
FLEET_BLUEMAP_BASE_PORT=8100

# --- Startup behavior ---
FLEET_STARTUP_TIMEOUT=180
FLEET_POLL_INTERVAL=5
